# Copiar a .env y completar. NO commitear .env.
APP_ENV=production
APP_DEBUG=false
APP_TZ=UTC

# Salt para hashear IPs de clicks (>=32 chars aleatorios). Cambiar por uno unico en prod.
APP_SALT=replace-with-a-random-string-of-at-least-32-chars

# MySQL
DB_HOST=localhost
DB_PORT=3306
DB_NAME=referedmkt
DB_USER=referedmkt
DB_PASS=

# Solo para desarrollo local: fuerza el tenant activo por dominio.
# DEV_SITE_DOMAIN=ciberseguridadpyme.local
