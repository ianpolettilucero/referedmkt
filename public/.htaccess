# -----------------------------------------------------------------------------
# Front controller: todo lo que no sea un archivo real va a index.php
# -----------------------------------------------------------------------------
<IfModule mod_rewrite.c>
    RewriteEngine On

    # Forzar HTTPS (Hostinger emite cert gratis via Let's Encrypt).
    RewriteCond %{HTTPS} !=on
    RewriteCond %{HTTP:X-Forwarded-Proto} !=https
    RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [R=301,L]

    # No rewritear si es un archivo/directorio real (assets, uploads, etc).
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # Resto -> index.php
    RewriteRule ^ index.php [L]
</IfModule>

# -----------------------------------------------------------------------------
# Security headers.
# -----------------------------------------------------------------------------
<IfModule mod_headers.c>
    # HSTS: fuerza HTTPS por 1 año, incluye subdominios. Activar preload solo
    # cuando estes seguro de que TODO el sitio es HTTPS, porque es dificil
    # revertir (Chrome/Firefox/Safari mantienen la preload list).
    Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains"

    # Impide MIME sniffing.
    Header set X-Content-Type-Options "nosniff"

    # Impide clickjacking (iframe externo).
    Header set X-Frame-Options "SAMEORIGIN"

    # Controla que info se filtra en Referer.
    Header set Referrer-Policy "strict-origin-when-cross-origin"

    # Desactiva FLoC + permisos innecesarios.
    Header set Permissions-Policy "interest-cohort=(), camera=(), microphone=(), geolocation=(), payment=()"

    # Cross-Origin-Opener-Policy: aisla browsing context (mitiga Spectre).
    Header set Cross-Origin-Opener-Policy "same-origin"

    # Cross-Origin-Resource-Policy: impide que terceros embedan tu contenido.
    Header set Cross-Origin-Resource-Policy "same-origin"

    # Oculta version de PHP / tecnologia (defensa contra fingerprinting).
    Header unset X-Powered-By
    Header unset Server
</IfModule>

# -----------------------------------------------------------------------------
# Evitar servir .env, .git, etc. (defensa en profundidad; no deberian estar en public/).
# -----------------------------------------------------------------------------
<FilesMatch "^\.">
    Require all denied
</FilesMatch>

<FilesMatch "\.(env|ini|log|sql|md)$">
    Require all denied
</FilesMatch>

# -----------------------------------------------------------------------------
# Compresion y cache.
# -----------------------------------------------------------------------------
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/css text/javascript application/javascript application/json image/svg+xml
</IfModule>

<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType image/png  "access plus 1 year"
    ExpiresByType image/webp "access plus 1 year"
    ExpiresByType image/svg+xml "access plus 1 year"
    ExpiresByType text/css "access plus 1 month"
    ExpiresByType application/javascript "access plus 1 month"
</IfModule>
