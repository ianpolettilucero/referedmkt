# -----------------------------------------------------------------------------
# Front controller: todo lo que no sea un archivo real va a index.php
# -----------------------------------------------------------------------------
<IfModule mod_rewrite.c>
    RewriteEngine On

    # Forzar HTTPS (Hostinger emite cert gratis via Let's Encrypt).
    RewriteCond %{HTTPS} !=on
    RewriteCond %{HTTP:X-Forwarded-Proto} !=https
    RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [R=301,L]

    # No rewritear si es un archivo/directorio real (assets, uploads, etc).
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # Resto -> index.php
    RewriteRule ^ index.php [L]
</IfModule>

# -----------------------------------------------------------------------------
# Security headers sanos por default.
# -----------------------------------------------------------------------------
<IfModule mod_headers.c>
    Header set X-Content-Type-Options "nosniff"
    Header set X-Frame-Options "SAMEORIGIN"
    Header set Referrer-Policy "strict-origin-when-cross-origin"
    Header set Permissions-Policy "interest-cohort=()"
</IfModule>

# -----------------------------------------------------------------------------
# Evitar servir .env, .git, etc. (defensa en profundidad; no deberian estar en public/).
# -----------------------------------------------------------------------------
<FilesMatch "^\.">
    Require all denied
</FilesMatch>

<FilesMatch "\.(env|ini|log|sql|md)$">
    Require all denied
</FilesMatch>

# -----------------------------------------------------------------------------
# Compresion y cache.
# -----------------------------------------------------------------------------
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/css text/javascript application/javascript application/json image/svg+xml
</IfModule>

<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType image/png  "access plus 1 year"
    ExpiresByType image/webp "access plus 1 year"
    ExpiresByType image/svg+xml "access plus 1 year"
    ExpiresByType text/css "access plus 1 month"
    ExpiresByType application/javascript "access plus 1 month"
</IfModule>
